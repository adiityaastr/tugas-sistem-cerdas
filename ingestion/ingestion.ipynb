    "---\n",
    "\n",
    "## Cell [5] — Fungsi Utility\n",
    "\n",
    "### Penjelasan\n",
    "\n",
    "Fungsi-fungsi helper untuk logging dan session management:\n",
    "\n",
    "| Fungsi | Fungsi |\n",
    "|--------|--------|\n",
    "| `timestamp()` | Format timestamp konsisten. |\n",
    "| `_get_session()` | Factory untuk database session. |\n",
    "| `log_start()` | Catat status `running` saat pipeline mulai. |\n",
    "| `log_result()` | Catat hasil pipeline: success/failed/empty. |\n",
    "| `stale_reset()` | Reset job yang stuck > 30 menit. |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def timestamp() -> str:\n",
    "    return datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "\n",
    "\n",
    "def _get_session():\n",
    "    engine = create_engine(DB_URL, echo=False)\n",
    "    Base.metadata.create_all(engine)\n",
    "    return sessionmaker(bind=engine)()\n",
    "\n",
    "\n",
    "def log_start(date_val: str):\n",
    "    \"\"\"Catat status RUNNING saat pipeline mulai.\"\"\"\n",
    "    session = _get_session()\n",
    "    existing = session.query(IngestionLog).filter(IngestionLog.date == date_val).first()\n",
    "    if existing:\n",
    "        existing.status = \"running\"\n",
    "        existing.retry_count = (existing.retry_count or 0) + 1\n",
    "        existing.started_at = timestamp()\n",
    "        existing.error_message = None\n",
    "        existing.finished_at = None\n",
    "    else:\n",
    "        session.add(IngestionLog(\n",
    "            date=date_val,\n",
    "            status=\"running\",\n",
    "            retry_count=1,\n",
    "            started_at=timestamp(),\n",
    "        ))\n",
    "    session.commit()\n",
    "    session.close()\n",
    "    print(f\"[{timestamp()}] LOG: status=running, date={date_val}\")\n",
    "\n",
    "\n",
    "def log_result(date_val: str, status: str, record_count: int,\n",
    "               method: str = None, error: str = None, duration: float = None):\n",
    "    \"\"\"Catat hasil pipeline: success/failed/empty.\"\"\"\n",
    "    session = _get_session()\n",
    "    entry = session.query(IngestionLog).filter(IngestionLog.date == date_val).first()\n",
    "    if entry:\n",
    "        entry.status = status\n",
    "        entry.record_count = record_count\n",
    "        entry.finished_at = timestamp()\n",
    "        entry.duration_seconds = duration\n",
    "        entry.error_message = error[:500] if error else None\n",
    "        entry.extraction_method = method\n",
    "        session.commit()\n",
    "    session.close()\n",
    "    print(f\"[{timestamp()}] LOG: status={status}, records={record_count}, method={method}\")\n",
    "\n",
    "\n",
    "def stale_reset():\n",
    "    \"\"\"Reset job yang stuck > 30 menit ke status failed.\"\"\"\n",
    "    session = _get_session()\n",
    "    cutoff = (datetime.now() - timedelta(minutes=STALE_TIMEOUT_MINUTES)).strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "    stale = (\n",
    "        session.query(IngestionLog)\n",
    "        .filter(IngestionLog.status == \"running\")\n",
    "        .filter(IngestionLog.started_at < cutoff)\n",
    "        .all()\n",
    "    )\n",
    "    for entry in stale:\n",
    "        entry.status = \"failed\"\n",
    "        entry.error_message = \"Stale — running > 30 menit, di-reset oleh stale_reset\"\n",
    "        print(f\"[{timestamp()}] STALE RESET: {entry.date} -> failed\")\n",
    "    if stale:\n",
    "        session.commit()\n",
    "    session.close()\n",
    "\n",
    "\n",
    "print(f\"[OK] Utility functions loaded\")"
   ]
